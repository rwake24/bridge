{
  "logLevel": "info",
  "platforms": {
    "mattermost": {
      "url": "https://chat.example.com",
      "access": {
        "mode": "allowlist",
        "users": ["your-username"]
      },
      "bots": {
        "copilot": {
          "token": "YOUR_BOT_TOKEN",
          "admin": true
        }
      }
    }
  },
  "channels": [
    {
      "id": "channel-id-from-mattermost",
      "platform": "mattermost",
      "bot": "copilot",
      "name": "My Project",
      "workingDirectory": "/path/to/project",
      "agent": null,
      "model": "claude-sonnet-4.6",
      "triggerMode": "mention",
      "threadedReplies": true,
      "verbose": false
    }
  ],
  "defaults": {
    "model": "claude-sonnet-4.6",
    "fallbackModels": [],
    "agent": null,
    "triggerMode": "mention",
    "threadedReplies": true,
    "verbose": false,
    "permissionMode": "interactive"
  },
  "infiniteSessions": false,
  "permissions": {
    "_comment": "CLI-compatible permission syntax: shell(cmd), write, read, MCP_SERVER(tool)",
    "allow": [
      "read",
      "shell(ls)",
      "shell(cat)",
      "shell(head)",
      "shell(tail)",
      "shell(find)",
      "shell(grep)",
      "shell(wc)"
    ],
    "deny": [
      "shell(rm)",
      "shell(git push)",
      "shell(git reset)",
      "shell(shutdown)",
      "shell(reboot)",
      "shell(halt)",
      "shell(systemctl poweroff)",
      "shell(networksetup)",
      "shell(diskutil)"
    ],
    "allowPaths": [],
    "allowUrls": [
      "docs.github.com",
      "learn.microsoft.com",
      "npmjs.com",
      "pypi.org",
      "crates.io",
      "pkg.go.dev",
      "nuget.org",
      "rubygems.org",
      "packagist.org",
      "maven.apache.org",
      "stackoverflow.com",
      "developer.mozilla.org"
    ]
  },
  "_comment_interAgent": "Optional: enable inter-agent communication (ask_agent tool)",
  "interAgent": {
    "enabled": false,
    "defaultTimeout": 60,
    "maxTimeout": 300,
    "maxDepth": 3,
    "allow": {
      "copilot": { "canCall": ["bob"], "canBeCalledBy": ["bob"] },
      "bob": { "canCall": ["copilot"], "canBeCalledBy": ["copilot"] }
    }
  },
  "_comment_scheduler": "Optional: config-defined recurring jobs. 'channel' must match a configured channel id or name.",
  "scheduler": {
    "timezone": "America/Chicago",
    "jobs": [
      {
        "id": "morning-briefing",
        "cron": "30 7 * * 1-5",
        "channel": "CHANNEL_ID_OR_NAME",
        "description": "Morning briefing",
        "prompt": "Good morning! Please give me a morning briefing: summarize any overnight emails addressed to me, list today's calendar events, highlight open tasks, and provide prep links for any meetings today.",
        "enabled": true
      },
      {
        "id": "email-scan",
        "cron": "0 8,10,12,14,16,18 * * 1-5",
        "channel": "CHANNEL_ID_OR_NAME",
        "description": "Email scan",
        "prompt": "Please scan my recent emails: filter for messages addressed directly to me, summarize each one briefly, and flag any that appear urgent or require a response today.",
        "enabled": true
      },
      {
        "id": "evening-recap",
        "cron": "0 17 * * 1-5",
        "channel": "CHANNEL_ID_OR_NAME",
        "description": "Evening recap",
        "prompt": "Please give me an end-of-day recap: summarize what was accomplished today, list any unresolved items or open threads, and give a brief preview of tomorrow's calendar and priorities.",
        "enabled": true
      },
      {
        "id": "weekly-pipeline",
        "cron": "0 8 * * 1",
        "channel": "CHANNEL_ID_OR_NAME",
        "description": "Weekly pipeline review",
        "prompt": "Please run the weekly pipeline review: check the status of all active accounts, flag any deals at risk, highlight upcoming renewals this week, and summarize motion status for each account.",
        "enabled": true
      }
    ]
  }
}
