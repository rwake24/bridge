{
  "platforms": {
    "mattermost": {
      "url": "https://chat.example.com",
      "botToken": "SINGLE_BOT_TOKEN",
      "_comment_bots": "OR use 'bots' for multiple identities:",
      "bots": {
        "copilot": { "token": "BOT_TOKEN_1", "admin": true },
        "bob": { "token": "BOT_TOKEN_2", "agent": "bob-agent" }
      }
    }
  },
  "channels": [
    {
      "id": "channel-id-from-mattermost",
      "platform": "mattermost",
      "bot": "copilot",
      "name": "My Project",
      "workingDirectory": "/path/to/project",
      "agent": null,
      "model": "claude-sonnet-4.6",
      "triggerMode": "mention",
      "threadedReplies": true,
      "verbose": false
    },
    {
      "id": "another-channel-id",
      "platform": "mattermost",
      "bot": "bob",
      "name": "Bob's Channel",
      "workingDirectory": "/path/to/other-project",
      "model": "claude-sonnet-4.6",
      "triggerMode": "mention",
      "threadedReplies": true,
      "verbose": false
    }
  ],
  "defaults": {
    "model": "claude-sonnet-4.6",
    "agent": null,
    "triggerMode": "mention",
    "threadedReplies": true,
    "verbose": false,
    "permissionMode": "interactive"
  },
  "permissions": {
    "_comment": "CLI-compatible permission syntax: shell(cmd), write, read, MCP_SERVER(tool)",
    "allow": [
      "read",
      "shell(ls)",
      "shell(cat)",
      "shell(head)",
      "shell(tail)",
      "shell(find)",
      "shell(grep)",
      "shell(wc)"
    ],
    "deny": [
      "shell(rm)",
      "shell(git push)",
      "shell(git reset)"
    ],
    "allowPaths": [],
    "allowUrls": [
      "docs.github.com",
      "learn.microsoft.com",
      "npmjs.com",
      "pypi.org",
      "crates.io",
      "pkg.go.dev",
      "nuget.org",
      "rubygems.org",
      "packagist.org",
      "maven.apache.org",
      "stackoverflow.com",
      "developer.mozilla.org"
    ]
  }
}
